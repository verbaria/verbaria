#!/bin/zsh
# Thin convenience wrapper around `mvn` for the post-migration Zanata stack.
# Most contributors should just invoke `mvn` directly; this script exists for
# muscle-memory parity with the pre-migration build helper.
#
# Examples:
#   ./build                    # compile + run unit tests (mvn install)
#   ./build --quick            # skip tests        (mvn install -DskipTests)
#   ./build --client           # build the CLI only
#   ./build --server           # build the Spring Boot server only
#   ./build --server --run     # start the server (after compile)
#   ./build -- -X clean install   # pass-through to mvn

set -e
cd "${0:A:h}"

quick=0
client=0
server=0
run_server=0

while (( $# )); do
  case "$1" in
    -Q|--quick)   quick=1; shift ;;
    --client)     client=1; shift ;;
    --server)     server=1; shift ;;
    --run)        run_server=1; shift ;;
    -h|--help)
      sed -n '2,18p' "$0"; exit 0 ;;
    --) shift; break ;;
    *)  break ;;
  esac
done

mvn_flags=()
(( quick )) && mvn_flags+=(-DskipTests)

if (( run_server )); then
  exec ./mvnw -pl server/zanata-server-spring -am "${mvn_flags[@]}" spring-boot:run "$@"
fi

projects=()
(( client )) && projects+=(-pl client -am)
(( server )) && projects+=(-pl server/zanata-server-spring -am)

exec ./mvnw "${projects[@]}" "${mvn_flags[@]}" install "$@"
