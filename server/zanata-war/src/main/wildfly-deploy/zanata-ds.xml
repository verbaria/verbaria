<?xml version="1.0" encoding="UTF-8"?>
<!-- Auto-deployed by WildFly when dropped into standalone/deployments/.
     The JDBC driver itself is the postgresql-42.7.4.jar deployed alongside
     this file; WildFly registers it as a driver under the jar's filename. -->
<datasources xmlns="urn:jboss:domain:datasources:7.2">
  <datasource jndi-name="java:jboss/datasources/zanataDatasource"
              pool-name="zanataDatasource"
              enabled="true"
              use-java-context="true">
    <connection-url>${zanata.db.url:jdbc:postgresql://localhost:5432/zanata}</connection-url>
    <driver>postgresql-42.7.4.jar</driver>
    <pool>
      <min-pool-size>1</min-pool-size>
      <max-pool-size>20</max-pool-size>
    </pool>
    <security>
      <user-name>${zanata.db.user:postgres}</user-name>
      <password>${zanata.db.password:1234}</password>
    </security>
    <validation>
      <check-valid-connection-sql>SELECT 1</check-valid-connection-sql>
      <validate-on-match>true</validate-on-match>
      <background-validation>false</background-validation>
    </validation>
  </datasource>
</datasources>
