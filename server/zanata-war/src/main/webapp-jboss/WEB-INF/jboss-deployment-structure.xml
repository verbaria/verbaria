<?xml version="1.0" encoding="UTF-8"?>

<!-- https://access.redhat.com/knowledge/docs/en-US/JBoss_Enterprise_Application_Platform/6/html/Development_Guide/Included_Modules1.html -->
<jboss-deployment-structure xmlns="urn:jboss:deployment-structure:1.2">
  <deployment>
    <!-- These exclusions let us use the war file's RESTEasy instead of the
         container's version -->
    <exclude-subsystems>
      <subsystem name="jaxrs" />
    </exclude-subsystems>
    <exclusions>
      <module name="jakarta.ws.rs.api" />
      <module name="javaee.api" />
      <module name="org.hibernate.search.orm" />
      <module name="org.jboss.as.jaxrs" />
      <!-- WildFly 32 ships an older jboss-logging-3.5 module which lacks
           Logger.getMessageLogger(MethodHandles.Lookup,Class,String); the
           WAR bundles 3.6.x which Hibernate Search 7's generated _$logger
           classes require. -->
      <module name="org.jboss.logging" />
      <!-- WildFly 32 ships Jackson 2.15.x; the WAR bundles 2.18.x.  When
           both are visible to the deployment classloader, Hibernate ORM
           (loaded from WildFly's module) instantiates a 2.15.x ObjectMapper
           that then discovers WAR-bundled 2.18.x Module SPI classes — and
           the class cast (Module 2.15 vs 2.18) fails.  Exclude WildFly's
           Jackson modules so only the WAR's 2.18.x is visible. -->
      <module name="com.fasterxml.jackson.core.jackson-core" />
      <module name="com.fasterxml.jackson.core.jackson-databind" />
      <module name="com.fasterxml.jackson.core.jackson-annotations" />
      <module name="com.fasterxml.jackson.datatype.jackson-datatype-jdk8" />
      <module name="com.fasterxml.jackson.datatype.jackson-datatype-jsr310" />
      <module name="com.fasterxml.jackson.jaxrs.jackson-jaxrs-json-provider" />
      <module name="com.fasterxml.jackson.jakarta.rs.jackson-jakarta-rs-json-provider" />
    </exclusions>
    <dependencies>

      <!-- needed by arquillian test -->
      <module name="com.h2database.h2" optional="true" />

      <!-- private module — present in WildFly 10-26, dropped from 27+ -->
      <module name="org.antlr" optional="true"/>

      <!-- start of deprecated modules -->
      <module name="org.jboss.security.negotiation" optional="true"/>
      <!-- end of deprecated modules -->

      <!-- sun.jdk was a WildFly-private alias for the JDK sun.* packages;
           dropped in WF 28 because the modules system now uses jdeps. -->
      <module name="sun.jdk" optional="true"/>

      <!-- PicketLink modules dropped from WildFly 16+; SAML 2.0 is now
           served by Elytron's federation extensions. The Zanata classes
           that referenced PicketLink (ExternalSAMLConfigurationProvider et
           al.) are kept in the WAR and use the bundled picketlink-* jars
           on the WAR classpath rather than container modules. -->
      <module name="org.picketlink" services="import" optional="true"/>
      <module name="org.picketlink.common" optional="true"/>

      <!-- All modules below are marked optional because the WildFly 32
           Galleon-provisioned distribution only ships a subset of legacy
           modules.  When a module is absent the WAR's own bundled jar is
           used; when present the container's is preferred. -->
      <module name="org.infinispan.commons" optional="true" />
      <module name="jakarta.annotation.api" optional="true" />
      <module name="jakarta.ejb.api" optional="true" />
      <module name="jakarta.inject.api" optional="true" />
      <module name="jakarta.el.api" optional="true" />
      <module name="jakarta.faces.api" optional="true" />
      <module name="jakarta.interceptor.api" optional="true" />
      <module name="jakarta.jms.api" optional="true" />
      <module name="jakarta.mail.api" optional="true" />
      <module name="jakarta.servlet.api" optional="true" />
      <module name="jakarta.transaction.api" optional="true"/>
      <module name="jakarta.validation.api" optional="true" />
      <module name="jakarta.xml.bind.api" optional="true" />
      <module name="org.apache.commons.logging" optional="true" />
      <module name="org.apache.log4j" optional="true" />
      <module name="org.dom4j" optional="true" />
      <module name="org.hibernate" optional="true" />
      <module name="org.hibernate.commons-annotations" optional="true" />
      <module name="org.hibernate.validator" optional="true" />
      <module name="org.slf4j" optional="true" />
      <module name="org.infinispan" optional="true" />
    </dependencies>
  </deployment>
</jboss-deployment-structure>
